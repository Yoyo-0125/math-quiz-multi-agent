DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_REQUEST_TIMEOUT=90
DEEPSEEK_GENERATOR_REQUEST_WARNING=60
DEEPSEEK_GENERATOR_REQUEST_TIMEOUT=120

# Optional fallback model. Per-agent models can also be set in config/pipeline_options.json.
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional OCR providers.
# TextIn / 合合信息:
TEXTIN_APP_ID=your_textin_app_id
TEXTIN_SECRET_CODE=your_textin_secret_code
TEXTIN_OCR_ENDPOINT=https://api.textin.com/ai/service/v1/handwritten_erase

# Youdao / 网易有道:
YOUDAO_APP_KEY=your_youdao_app_key
YOUDAO_APP_SECRET=your_youdao_app_secret
YOUDAO_OCR_ENDPOINT=https://openapi.youdao.com/ocr_writing_erase
# The writing-erase API uses q for the image base64 field.
YOUDAO_IMAGE_FIELD=q
# Optional URL-encoded extra params, for example: langType=zh-CHS&detectType=10012
YOUDAO_OCR_EXTRA_PARAMS=

# Optional: load provider credentials from extra env files separated by ; on Windows or : on macOS/Linux.
# OCR_ENV_FILES=C:\path\textin.env;C:\path\youdao.env
# TEXTIN_ENV_FILE=C:\path\textin.env
# YOUDAO_ENV_FILE=C:\path\youdao.env
