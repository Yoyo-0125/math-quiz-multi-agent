{
  "input": "examples/input.md",
  "output_dir": "outputs",
  "review_threshold": 80,
  "max_review_rounds": 2,
  "qc_threshold": 90,
  "max_qc_rounds": 4,
  "max_generated_questions": 1,
  "generation_profile": {
    "question_count": 1,
    "question_count_mode": "match_source",
    "difficulty": "match_input",
    "knowledge_points": "",
    "question_types": "",
    "style": "match_input",
    "answer_detail": "concise",
    "allow_input_compaction": false
  },
  "models": {
    "default": "deepseek-v4-pro",
    "decomposer": "deepseek-v4-pro",
    "reviewer": "deepseek-v4-pro",
    "generator": "deepseek-v4-pro",
    "qc": "deepseek-v4-pro",
    "reader": "deepseek-v4-pro"
  },
  "thinking": {
    "decomposer": false,
    "reviewer": false,
    "generator": true,
    "qc": false,
    "reader": false
  },
  "reasoning_effort": {
    "decomposer": "medium",
    "reviewer": "medium",
    "generator": "high",
    "qc": "high",
    "reader": "medium"
  },
  "token_budget": {
    "total_warning": 320000,
    "total_stop": 480000,
    "single_warning": 100000,
    "single_stop": 150000
  }
}
